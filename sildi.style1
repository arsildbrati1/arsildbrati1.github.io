<!DOCTYPE html>
<html lang="sq">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SILDI STYLE</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial,sans-serif;
    background:#f5f5f5;
}

/* HEADER */
header{
    background:white;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px;
    position:sticky;
    top:0;
}

.logo h1{
    font-size:40px;
}

.logo p{
    color:#c8a96a;
    letter-spacing:3px;
}

.menu-btn{
    font-size:35px;
    border:none;
    background:none;
    cursor:pointer;
}

/* MENU */
nav{
    background:black;
    text-align:center;
    display:none;
    padding:15px;
}

nav a{
    display:block;
    color:white;
    text-decoration:none;
    margin:10px;
    font-size:18px;
}

/* HERO */
.hero{
    background:url('https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=1200')
    center/cover;
    height:500px;
    color:white;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
}

.hero h2{
    font-size:45px;
}

.hero p{
    margin:15px 0;
    font-size:20px;
}

.hero button{
    padding:15px 30px;
    border:none;
    border-radius:10px;
    background:#c8a96a;
    color:white;
    font-size:18px;
    cursor:pointer;
}

/* PRODUCTS */
.products{
    padding:30px;
    text-align:center;
}

.products h2{
    margin-bottom:25px;
    font-size:35px;
}

.product-grid{
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
    gap:20px;
}

.card{
    background:white;
    width:280px;
    border-radius:15px;
    overflow:hidden;
    box-shadow:0 0 10px rgba(0,0,0,0.2);
}

.card img{
    width:100%;
    height:300px;
    object-fit:cover;
}

.card-content{
    padding:15px;
}

.price{
    color:#c8a96a;
    font-size:22px;
    font-weight:bold;
}

/* ABOUT */
.about{
    text-align:center;
    padding:40px 20px;
}

/* FORMULARI */
.message-form{
    background:white;
    margin:20px;
    padding:30px;
    border-radius:15px;
    text-align:center;
    box-shadow:0 0 10px rgba(0,0,0,0.1);
}

.message-form h2{
    margin-bottom:20px;
}

.message-form input,
.message-form textarea{
    width:100%;
    padding:15px;
    margin:10px 0;
    border:1px solid #ddd;
    border-radius:10px;
    font-size:16px;
}

.message-form textarea{
    height:120px;
    resize:none;
}

.message-form button{
    background:#c8a96a;
    color:white;
    border:none;
    padding:15px 30px;
    border-radius:10px;
    font-size:18px;
    cursor:pointer;
}

/* FOOTER */
footer{
    background:black;
    color:white;
    text-align:center;
    padding:20px;
    margin-top:20px;
}
</style>
</head>

<body>

<header>
    <div class="logo">
        <h1>SILDI</h1>
        <p>STYLE</p>
    </div>

    <button class="menu-btn"
    onclick="toggleMenu()">☰</button>
</header>

<nav id="menu">
    <a href="#">Kryefaqja</a>
    <a href="#">Produkte</a>
    <a href="#">Oferta</a>
    <a href="#">Kontakt</a>
</nav>

<section class="hero">
    <h2>Moda më e fundit</h2>
    <p>Stile moderne dhe elegante</p>

    <button>SHIKO KOLEKSIONIN</button>
</section>

<section class="products">
    <h2>Produktet Tona</h2>

    <div class="product-grid">

        <div class="card">
            <img src="https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=500">

            <div class="card-content">
                <h3>Bluzë Klasike</h3>
                <p class="price">1500 Lekë</p>
            </div>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1541099649105-f69ad21f3246?w=500">

            <div class="card-content">
                <h3>Pantallona Modern</h3>
                <p class="price">2800 Lekë</p>
            </div>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=500">

            <div class="card-content">
                <h3>Atlete Premium</h3>
                <p class="price">3500 Lekë</p>
            </div>
        </div>

    </div>
</section>

<section class="about">
    <h2>Rreth Nesh</h2>

    <p>
        Dyqani juaj i besuar i modës.
        Produkte moderne me cilësi dhe çmime të mira.
    </p>
</section>

<!-- FORMULARI -->
<section class="message-form">
    <h2>Na Dërgo Mesazh</h2>

    <form onsubmit="sendMessage(event)">

        <input
        type="text"
        id="name"
        placeholder="Emri juaj"
        required>

        <input
        type="email"
        id="email"
        placeholder="Email juaj"
        required>

        <textarea
        id="message"
        placeholder="Shkruaj mesazhin..."
        required></textarea>

        <button type="submit">
            Dërgo Mesazh
        </button>

    </form>
</section>

<footer>
    <p>© 2025 SILDI STYLE</p>
</footer>

<script>
function toggleMenu(){
    let menu =
    document.getElementById("menu");

    if(menu.style.display==="block"){
        menu.style.display="none";
    } else {
        menu.style.display="block";
    }
}

function sendMessage(event){
    event.preventDefault();

    let name =
    document.getElementById("name").value;

    alert(
    "Mesazhi u dergua me sukses, "
    + name + "!"
    );
}
</script>

</body>
</html>
